# =============================================================================
# CONFIGURATION DJANGO - Venus Luna E-commerce
# =============================================================================
# Copiez ce fichier vers .env et remplissez les valeurs
# NE JAMAIS PUSHER .env SUR GITHUB!

# --- SÉCURITÉ ---
SECRET_KEY=votre_secret_key_a_generer
DEBUG=False
ALLOWED_HOSTS=venus-luna.com,www.venus-luna.com

# --- BASE DE DONNÉES POSTGRESQL ---
DB_NAME=venus-luna
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe_bdd
DB_HOST=localhost
DB_PORT=5432

# --- CLOUDINARY (Stockage d'images) ---
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# --- PAYPLUS AFRICA (Paiement) ---
PAYPLUS_API_KEY=votre_payplus_api_key
PAYPLUS_MERCHANT_ID=votre_merchant_id
SITE_URL=https://venus-luna.com

# --- BKAPAY (Paiement) ---
BKAPAY_PUBLIC_KEY=votre_bkapay_public_key
BKAPAY_SECRET_WEBHOOK=votre_bkapay_webhook_secret

# --- EMAIL (Gmail) ---
EMAIL_USER=votre_email@gmail.com
EMAIL_APP_PASSWORD=votre_app_password_gmail

# --- RÉSEAUX SOCIAUX ---
WHATSAPP_NUMBER=22893343403
FACEBOOK_URL=https://www.facebook.com/venustogo
TWITTER_URL=https://twitter.com/venustogo
INSTAGRAM_URL=https://www.instagram.com/venustogo/
LINKEDIN_URL=https://www.linkedin.com/company/venustogo/
TIKTOK_URL=https://www.tiktok.com/@venustogo
